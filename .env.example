# Environment configuration for Your Shikshak Backend
# NODE_ENV determines the environment (development, production, test)
NODE_ENV=development

# Port on which the server will run
PORT=5000

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/yourshikshak

# JWT secrets and expiry durations
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_refresh_secret_key_here
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# CORS allowed origins for frontend (web) and mobile
ALLOWED_ORIGIN=http://localhost:3000
MOBILE_APP_ORIGINS=capacitor://localhost,http://localhost

# Logger level (error, warn, info, http, verbose, debug, silly)
LOG_LEVEL=info

# Cloudinary (for document uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=yourshikshak/documents

# Firebase Cloud Messaging (service account)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
# Base64-encoded private key string (encode JSON key's private_key value)
FIREBASE_PRIVATE_KEY=your_base64_encoded_private_key
